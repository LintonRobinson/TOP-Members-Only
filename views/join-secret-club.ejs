<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Google Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/styles/output.css">
    <link rel="icon" type="image/png" href="/assets/paper-plane.png">
    <title>Shhhh🤫</title>
</head>

<body class="h-screen relative bg-neutral-900 text-slate-50">
    <%- include("partials/navbar") %>
        <main class="flex flex-col justify-center items-center relative pt-30">
            <div class="flex flex-col gap-9 bg-zinc-800 p-10 border border-neutral-700 rounded-md w-md">
                <h1 class="text-4xl">Join The Secret Club</h1>
                <form class="flex flex-col  text-neutral-400" action="/secret-club/join" method="POST">
                    <div class="flex flex-col gap-6 pb-8 mb-8 border-b border-neutral-700">
                        <label class="flex flex-col gap-2">
                            Who is twinkle toes?:
                            <input placeholder="Take your best guess...."
                                class="bg-black p-1.5 border border-neutral-700 rounded-md focus:border-cyan-200  outline-none transition-all"
                                type="password" name="secretClubRiddle" required>
                        </label>

                    </div>
                    <button class="bg-cyan-200 text-black p-1.5 border border-neutral-700 rounded-md cursor-pointer"
                        type="submit">Submit</button>
                </form>
                <%- include("partials/errors") %>
                    <% if(locals.secretClubSuccess) { %>
                        <div>
                            <span>Success!</span>
                            <a class="text-cyan-200" href="/">Go Home</a>

                        </div>
                        <% } %>
            </div>
        </main>
        <%- include("partials/footer") %>
</body>

</html>