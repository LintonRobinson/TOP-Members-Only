<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles/error-page.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Google Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/styles/sign-up.css">
    <link rel="icon" type="image/png" href="/assets/">
    <title>Log In</title>
</head>

<body>
    <main>
        <h1>Join The Secret Club</h1>
        <form action="/secret-club/join" method="POST">
            <label>
                Who is twinkle toes?:
                <input type="password" name="secretClubRiddle" required>
            </label>
            <button type="submit">Submit</button>
        </form>
        <%- include("partials/errors") %>
            <% if(locals.secretClubSuccess) { %>
                <div>
                    <span>Success!</span>
                    <a href="">View Secret Club Members</a>
                    <a href="/"> View All Messages</a>
                </div>

                <% } %>
    </main>

</body>

</html>